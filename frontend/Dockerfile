# Используем легковесный образ Node.js на базе Debian Bookworm
FROM node:20-bookworm-slim

# Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# Сначала копируем только файлы манифестов
# Это критически важно для кэширования слоев Docker. 
# npm install выполнится повторно только если изменятся эти файлы.
COPY package*.json ./

# Устанавливаем зависимости
RUN npm install

# Теперь копируем все остальные файлы проекта
COPY . .

# Сообщаем Docker, какой порт будет использоваться внутри контейнера.
# Мы используем стандартный порт Vite 5173.
EXPOSE 5173

# Запускаем сервер разработки.
# --host 0.0.0.0 — обязателен, иначе Vite будет слушать только внутри контейнера 
# и вы не сможете открыть сайт в браузере на Debian.
# --port 5173 фиксирует порт внутри, чтобы docker-compose мог его пробросить.
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "5173"]